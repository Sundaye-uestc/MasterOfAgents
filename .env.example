# ============================================================
# AgentHub — 环境配置
# ============================================================

# ---- AI Provider（任务规划 LLM）----
# 用于将用户 Prompt 分解为多 Agent 协作任务计划
# 可选值: anthropic, dashscope, deepseek, dobrain, moonshot, openai, openrouter, glm
PLANNER_PROVIDER=deepseek-v4-flash

# 模型名称（可选，各 Provider 有默认模型）
PLANNER_MODEL=deepseek-v4-flash

# API Key（选择哪个 Provider 就填哪个 Key）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DOBRAIN_API_KEY=your_dobrain_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GLM_API_KEY=your_glm_api_key_here

# ---- PPT 图片生成 (NanoBanana / Gemini) ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- 可灵 AI（视频转场，可选）----
# KLING_ACCESS_KEY=your_kling_access_key_here
# KLING_SECRET_KEY=your_kling_secret_key_here
