{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:all",
      "detail": "启动后端 (3001) + 前端 (5173)",
      "dependsOn": ["dev:server", "dev:web"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "dev:server",
      "detail": "启动后端服务 Hono + WebSocket",
      "type": "shell",
      "command": "Get-Content '${workspaceFolder}\\.env' -ErrorAction SilentlyContinue | Where-Object { $_ -match '^\\s*([^#].+?)=(.+)$' } | ForEach-Object { [System.Environment]::SetEnvironmentVariable($matches[1], $matches[2].Trim('\"').Trim(\"'\")) }; pnpm --filter @agenthub/server dev",
      "options": {
        "cwd": "${workspaceFolder}/AgentHub"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "server",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*\\[AgentHub Server\\].*",
          "endsPattern": "^.*\\[AgentHub Server\\].*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "server"
      }
    },
    {
      "label": "dev:web",
      "detail": "启动前端开发服务器 Vite + React",
      "type": "shell",
      "command": "pnpm --filter @agenthub/web dev",
      "options": {
        "cwd": "${workspaceFolder}/AgentHub"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "web",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Local:.*",
          "endsPattern": "^.*Local:.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "web"
      }
    },
    {
      "label": "pnpm install",
      "detail": "安装所有依赖",
      "type": "shell",
      "command": "pnpm install",
      "options": {
        "cwd": "${workspaceFolder}/AgentHub"
      },
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}